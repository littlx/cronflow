# /etc/cronflow/cronflow.env — 运行配置覆盖 (可选)
# systemd unit 会优先读这里, 覆盖 Environment= 默认值。
# 修改后: sudo systemctl restart cronflow

# 数据库 (sqlite+aiosqlite 协议)
# DATABASE_URL=sqlite+aiosqlite:////var/lib/cronflow/cronflow.db

# 前端静态文件 (打包后的 dist 目录所在路径)
# STATIC_DIR=/opt/cronflow/backend/dist

# 执行层
# MAX_CONCURRENCY=8
# TASK_RETRY_MAX=3
# TASK_RETRY_BACKOFF=2.0
# TASK_DEFAULT_TIMEOUT=300

# 数据保留
# LOG_RETENTION_DAYS=90
# CACHE_RETENTION_DAYS=30

# 调度
# SCHEDULER_TICK_SECONDS=5

# 认证 (生产环境建议接 JWT 后置 true)
# AUTH_ENABLED=false
# SECRET_KEY=change-me

# 跨域 (同域部署不需要)
# CORS_ORIGINS=["https://cronflow.internal"]
